---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const aboutEntry = await getEntry('about', 'about');
const pricingEntry = await getEntry('pricing', 'pricing');
const historyEntry = await getEntry('history', 'history');

const aboutRender = aboutEntry ? await aboutEntry.render() : null;
const historyRender = historyEntry ? await historyEntry.render() : null;
---

<BaseLayout>
  <!-- Navigation -->
  <header class="sticky top-0 z-50 border-b border-brand-200/80 bg-brand-50/95 backdrop-blur supports-[backdrop-filter]:bg-brand-50/80">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6" aria-label="Hlavná navigácia">
      <a href="#" class="font-display text-xl font-semibold tracking-tight text-brand-800 sm:text-2xl">PÁNI ELEGÁNI</a>
      <ul class="flex gap-6 text-sm font-medium text-brand-700">
        <li><a href="#o-nas" class="hover:text-brand-900">O nás</a></li>
        <li><a href="#cennik" class="hover:text-brand-900">Cenník</a></li>
        <li><a href="#historia" class="hover:text-brand-900">História</a></li>
        <li><a href="#rezervacia" class="rounded-full bg-brand-800 px-4 py-2 text-brand-50 hover:bg-brand-900">Rezervácia</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <section id="hero" class="relative overflow-hidden px-4 py-20 sm:px-6 sm:py-28 md:py-36">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-display text-4xl font-semibold tracking-tight text-brand-900 sm:text-5xl md:text-6xl">
          PÁNI ELEGÁNI
        </h1>
        <p class="mt-4 font-sans text-lg text-brand-700 sm:text-xl">
          Kde štýl stretáva tradíciu. Váš barber shop v srdci mesta.
        </p>
        <a href="#rezervacia" class="mt-8 inline-block rounded-full bg-brand-800 px-8 py-3 font-medium text-brand-50 shadow-lg transition hover:bg-brand-900 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:ring-offset-2">
          Rezervovať termín
        </a>
      </div>
    </section>

    <!-- O nás -->
    <section id="o-nas" class="border-t border-brand-200 bg-white px-4 py-16 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-3xl">
        <h2 class="font-display text-3xl font-semibold text-brand-900 sm:text-4xl">O nás</h2>
        <div class="mt-6 space-y-4 font-sans text-brand-700 leading-relaxed prose prose-brand max-w-none">
          {aboutRender && <aboutRender.Content />}
          {!aboutEntry && (
            <>
              <p>Vitajte v PÁNOCH ELEGÁNOCH – barber shopu, kde sa staráme o váš vzhľad s dôrazom na detail a pohodu.</p>
              <p>Naši barberi majú skúsenosti a záleží nám na tom, aby ste odchádzali spokojní.</p>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- Cenník -->
    <section id="cennik" class="border-t border-brand-200 px-4 py-16 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-3xl">
        <h2 class="font-display text-3xl font-semibold text-brand-900 sm:text-4xl">Cenník</h2>
        <ul class="mt-8 space-y-4 font-sans" role="list">
          {pricingEntry?.data.items.map((item) => (
            <li class="flex justify-between border-b border-brand-200 py-3 last:border-0">
              <span class="text-brand-800">{item.name}</span>
              <span class="font-medium text-brand-900">{item.price} €</span>
            </li>
          ))}
          {!pricingEntry && (
            <>
              <li class="flex justify-between border-b border-brand-200 py-3"><span class="text-brand-800">Strih</span><span class="font-medium text-brand-900">15 €</span></li>
              <li class="flex justify-between border-b border-brand-200 py-3"><span class="text-brand-800">Strih + brada</span><span class="font-medium text-brand-900">22 €</span></li>
              <li class="flex justify-between py-3"><span class="text-brand-800">Holenie brýtkou</span><span class="font-medium text-brand-900">18 €</span></li>
            </>
          )}
        </ul>
        <p class="mt-6 text-sm text-brand-600">{pricingEntry?.data.note ?? 'Ceny sú orientačné. Aktuálny cenník môžete overiť pri rezervácii.'}</p>
      </div>
    </section>

    <!-- História -->
    <section id="historia" class="border-t border-brand-200 bg-white px-4 py-16 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-3xl">
        <h2 class="font-display text-3xl font-semibold text-brand-900 sm:text-4xl">História</h2>
        <div class="mt-6 space-y-4 font-sans text-brand-700 leading-relaxed prose prose-brand max-w-none">
          {historyRender && <historyRender.Content />}
          {!historyEntry && (
            <>
              <p>PÁNI ELEGÁNI vznikli z lásky k remeslu a k tradičnej barber kultúre.</p>
              <p>Od otvorenia sa snažíme držať vysoký štandard služieb a vytvárať vernú komunitu zákazníkov.</p>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- Rezervácia -->
    <section id="rezervacia" class="border-t border-brand-200 px-4 py-16 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-3xl">
        <h2 class="font-display text-3xl font-semibold text-brand-900 sm:text-4xl">Rezervácia</h2>
        <p class="mt-4 font-sans text-brand-700">
          Vyberte si termín a službu. Po potvrdení vám príde e-mail s odkazom do kalendára.
        </p>
        <!-- Cal.com embed placeholder – nahradíte skutočným embed kódom z Cal.com -->
        <div class="cal-embed mt-8 min-h-[400px] rounded-xl border border-brand-200 bg-white p-6 shadow-sm" data-cal-link="">
          <p class="text-center font-sans text-brand-600">
            Tu bude vložený Cal.com rezervačný widget. Po nastavení Cal.com sem vložte embed kód.
          </p>
          <p class="mt-2 text-center text-sm text-brand-500">
            Napr. <code class="rounded bg-brand-100 px-1">data-cal-link="vase-meno/30min"</code> v konfigurácii Cal.com.
          </p>
        </div>
      </div>
    </section>

    <!-- Kontakt / Footer -->
    <footer class="border-t border-brand-200 bg-brand-100/50 px-4 py-12 sm:px-6">
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
          <div>
            <span class="font-display text-xl font-semibold text-brand-900">PÁNI ELEGÁNI</span>
            <p class="mt-1 font-sans text-sm text-brand-700">Barber shop</p>
          </div>
          <div class="text-center font-sans text-sm text-brand-700 sm:text-left">
            <p>Adresa: [Vaša adresa]</p>
            <p class="mt-1">Tel: [Vaše číslo]</p>
            <p class="mt-1">E-mail: [Váš e-mail]</p>
          </div>
        </div>
        <p class="mt-8 text-center font-sans text-xs text-brand-600">
          © {new Date().getFullYear()} PÁNI ELEGÁNI. Všetky práva vyhradené.
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>
