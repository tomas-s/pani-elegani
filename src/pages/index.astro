---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const aboutEntry = await getEntry('about', 'about');
const pricingEntry = await getEntry('pricing', 'pricing');
const historyEntry = await getEntry('history', 'history');
const reviewsEntry = await getEntry('reviews', 'google');

const aboutRender = aboutEntry ? await aboutEntry.render() : null;
const historyRender = historyEntry ? await historyEntry.render() : null;

const pricingCategories = pricingEntry?.data.categories ?? (pricingEntry?.data.items ? [{ name: 'Služby', items: pricingEntry.data.items }] : []);
const reviews = reviewsEntry?.data.reviews ?? [];
const googleProfileUrl = reviewsEntry?.data.googleProfileUrl ?? '#';
---

<BaseLayout>
  <!-- Navigation -->
  <header class="fixed top-0 w-full z-50 transition-all duration-300 bg-ink/95 backdrop-blur-md border-b border-white/5" id="navbar">
    <nav class="max-w-6xl mx-auto flex items-center justify-between px-6 py-5" aria-label="Hlavná navigácia">
      <a href="#" class="font-display text-2xl font-bold tracking-[0.15em] text-white uppercase flex items-center gap-2">
        <span class="text-accent">Páni</span> Elegáni
      </a>
      <div class="flex items-center gap-8">
        <ul class="hidden md:flex gap-8 text-[13px] uppercase tracking-widest font-semibold font-sans text-white/70">
          <li><a href="#" class="text-accent transition-colors py-2">Domov</a></li>
          <li><a href="#o-nas" class="hover:text-accent transition-colors py-2">O nás</a></li>
          <li><a href="#cennik" class="hover:text-accent transition-colors py-2">Cenník</a></li>
          <li><a href="#historia" class="hover:text-accent transition-colors py-2">História</a></li>
          {reviews.length > 0 && <li><a href="#recenzie" class="hover:text-accent transition-colors py-2">Recenzie</a></li>}
        </ul>
        <a
          href="https://pani-elegani.reservio.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-block rounded-pill border-2 border-accent text-accent hover:bg-accent hover:text-white transition-colors py-2 px-6 font-sans text-[12px] uppercase tracking-widest font-bold"
        >
          Rezervácia
        </a>
      </div>
    </nav>
  </header>

  <main class="w-full">
    <!-- Hero -->
    <section id="hero" class="w-full min-h-[90vh] flex flex-col justify-center items-center text-center bg-ink slanted-bottom relative z-10 pt-32 pb-40 px-6">
      <div class="absolute inset-0 bg-gradient-to-b from-ink/50 to-ink pointer-events-none"></div>
      <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">
        <p class="hero-anim hero-anim-d1 text-accent uppercase tracking-[0.3em] text-[12px] sm:text-[14px] font-bold mb-6 flex items-center gap-4">
          <span class="w-12 h-px bg-accent/50 hidden sm:block"></span>
          Najlepší Barber shop v meste
          <span class="w-12 h-px bg-accent/50 hidden sm:block"></span>
        </p>
        <h1 class="hero-anim hero-anim-d2 font-display text-white text-[56px] sm:text-[80px] md:text-[100px] font-bold leading-[1.05] tracking-tight mb-10">
          Remeslo <span class="text-white/90 italic font-medium">s citom</span>
        </h1>
        <p class="hero-anim hero-anim-d3 text-[18px] sm:text-[20px] leading-relaxed mb-12 text-white/70 font-sans max-w-xl mx-auto">
          Barber shop Páni Elegáni je vaše tiché útočisko. Oddýchnite si a odchádzajte s novým sebavedomím.
        </p>
        <div class="hero-anim hero-anim-d4 flex flex-col sm:flex-row gap-6">
          <a
            href="https://pani-elegani.reservio.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-pill py-4 px-10 bg-accent font-sans text-[13px] uppercase tracking-widest text-white font-bold hover:bg-accentHover transition-colors shadow-lg"
          >
            Rezervovať termín
          </a>
          <a
            href="#o-nas"
            class="rounded-pill py-4 px-10 bg-white font-sans text-[13px] uppercase tracking-widest text-ink font-bold hover:bg-gray-100 transition-colors shadow-lg"
          >
            Zistiť viac
          </a>
        </div>
      </div>
      
      <!-- Dots indicator (decoration) -->
      <div class="absolute bottom-16 left-1/2 -translate-x-1/2 flex gap-3 z-10">
        <div class="w-2.5 h-2.5 rounded-full bg-white"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-white/30"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-white/30"></div>
      </div>
    </section>

    <!-- O nás -->
    <section id="o-nas" class="w-full py-32 bg-parchment relative z-0 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <!-- Text content -->
        <div class="flex flex-col items-start text-left">
          <div class="reveal flex items-center gap-4 mb-6">
            <h2 class="text-[40px] md:text-[56px] leading-[1.1] text-ink font-display font-bold">
              {aboutEntry?.data?.subtitle ?? 'Dôraz na detail'}
            </h2>
            <div class="w-16 h-px bg-accent mt-2"></div>
          </div>
          <div class="reveal rendered-content text-[17px] leading-relaxed text-ink/70 font-sans mb-12" data-delay="80">
            {aboutRender
              ? <aboutRender.Content />
              : <p>Vitajte v PÁNOCH ELEGÁNOCH – barber shope, kde sa staráme o váš vzhľad s dôrazom na detail a pohodu. Konzultácia, strih, úprava brady – všetko s rešpektom k vašej osobnosti. Záleží nám na tom, aby ste sa u nás cítili ako doma a odchádzali oddýchnutí.</p>
            }
          </div>
          
          <div class="reveal grid sm:grid-cols-2 gap-8 w-full" data-delay="160">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 shrink-0 text-accent">
                <!-- SVG Icon (Razor/Blade placeholder) -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m20 9-4.5 4.5"/><path d="M12 22a2.83 2.83 0 0 0 4-4l-8-8a2.83 2.83 0 0 0-4 4Z"/><path d="m6 10 4.5-4.5"/><path d="m14 4 4 4"/><path d="m4 14 4 4"/></svg>
              </div>
              <div>
                <h3 class="font-display font-bold text-ink text-[16px] uppercase tracking-wide mb-2">Skvelé ceny</h3>
                <p class="font-sans text-[14px] text-graphite leading-relaxed">Kvalitné služby za bezkonkurenčnú cenu.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 shrink-0 text-accent">
                <!-- SVG Icon (Comb/Scissor placeholder) -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" x2="8.12" y1="4" y2="15.88"/><line x1="14.47" x2="14.48" y1="14.48" y2="14.47"/><line x1="8.12" x2="20" y1="8.12" y2="20"/></svg>
              </div>
              <div>
                <h3 class="font-display font-bold text-ink text-[16px] uppercase tracking-wide mb-2">Rýchly servis</h3>
                <p class="font-sans text-[14px] text-graphite leading-relaxed">Úžasná služba vybavená za pár minút.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Image placeholder area (mimicking the stacked photos from the design) -->
        <div class="reveal relative h-[500px] bg-subtle/50 rounded-lg overflow-hidden border border-subtle flex items-center justify-center" data-delay="160">
           <!-- If there was an image, we'd place it here. Using a stylish placeholder. -->
           <div class="text-center p-8">
             <div class="font-display text-[120px] text-graphite/20 font-bold leading-none select-none">PE</div>
             <p class="font-sans text-graphite uppercase tracking-widest text-sm mt-4">Páni Elegáni</p>
           </div>
        </div>
      </div>
    </section>

    <!-- História (Quote section) -->
    <section id="historia" class="w-full py-40 bg-ink text-white slanted-top-bottom relative z-10 px-6 flex flex-col items-center justify-center text-center">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-ink via-ink to-[#0a0a0a] pointer-events-none"></div>
      
      <div class="relative z-10 max-w-5xl mx-auto">
        <div class="text-accent text-7xl font-display leading-none mb-4 opacity-80">”</div>
        
        <h2 class="reveal text-[32px] md:text-[48px] leading-[1.3] text-white font-display font-bold mb-8 uppercase tracking-wide">
          <span class="text-white/70">Myslím si, že najdôležitejšia vec, ktorú muž môže mať –</span>
          <span class="text-accent">okrem talentu, samozrejme</span>
          <span class="text-white/70"> – je jeho holič.</span>
        </h2>
        
        <div class="reveal flex flex-col items-center gap-2" data-delay="80">
          <p class="text-accent font-sans text-[16px] uppercase tracking-[0.2em] font-bold">
            {historyEntry?.data?.subtitle ?? 'Láska k remeslu'}
          </p>
          <div class="w-8 h-px bg-white/30 my-2"></div>
          <div class="rendered-content text-[15px] leading-relaxed text-white/60 font-sans max-w-2xl">
            {historyRender
              ? <historyRender.Content />
              : <p>PÁNI ELEGÁNI vznikli z túžby po autentickej barber kultúre. Chceli sme vytvoriť miesto, kde muž príde, oddýchne si a odchádza s novým sebavedomím.</p>
            }
          </div>
        </div>
      </div>
      
      <!-- Dots indicator (decoration) -->
      <div class="absolute bottom-16 left-1/2 -translate-x-1/2 flex gap-3 z-10">
        <div class="w-2.5 h-2.5 rounded-full bg-white"></div>
      </div>
    </section>

    <!-- Cenník -->
    <section id="cennik" class="w-full py-32 bg-parchment relative z-0 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-20 reveal">
          <p class="text-[13px] tracking-[0.2em] uppercase mb-4 text-accent font-sans font-bold">Naša ponuka</p>
          <div class="flex items-center justify-center gap-6">
            <div class="w-12 h-px bg-ink/20"></div>
            <h2 class="text-[48px] leading-[1.2] text-ink font-display font-bold">
              Cenník služieb
            </h2>
            <div class="w-12 h-px bg-ink/20"></div>
          </div>
        </div>

        {pricingCategories.length > 0 ? (
          <div class="reveal" data-delay="80">
            <!-- Tab list -->
            <div class="flex justify-center mb-12" role="tablist" aria-label="Kategórie cenníka">
              <div class="flex flex-wrap justify-center gap-2 sm:gap-8 border-b-2 border-subtle pb-px">
                {pricingCategories.map((cat, i) => (
                  <button
                    type="button"
                    role="tab"
                    aria-selected={i === 0}
                    aria-controls={`cennik-panel-${i}`}
                    id={`cennik-tab-${i}`}
                    data-tab-index={i}
                    class="cennik-tab px-4 py-4 font-sans text-[14px] uppercase tracking-widest font-bold text-graphite hover:text-ink transition-all focus:outline-none data-[active]:text-accent relative after:content-[''] after:absolute after:bottom-[-2px] after:left-0 after:w-full after:h-0.5 after:bg-transparent data-[active]:after:bg-accent"
                    data-active={i === 0 ? '' : undefined}
                  >
                    {cat.name}
                  </button>
                ))}
              </div>
            </div>
            <!-- Tab panels -->
            <div class="max-w-3xl mx-auto">
              {pricingCategories.map((cat, i) => (
                <div
                  role="tabpanel"
                  id={`cennik-panel-${i}`}
                  aria-labelledby={`cennik-tab-${i}`}
                  hidden={i !== 0}
                  class="cennik-panel"
                  data-panel-index={i}
                >
                  <ul class="font-sans flex flex-col" role="list">
                    {cat.items.map((item, idx) => (
                      <li class={`flex justify-between items-center py-6 ${idx !== cat.items.length - 1 ? 'border-b border-subtle/50 border-dashed' : ''} group`}>
                        <div class="flex flex-col gap-1.5 pr-6">
                          <span class="text-[20px] text-ink font-display font-bold">{item.name}</span>
                          {item.description && (
                             <span class="text-[14px] text-graphite/80 leading-snug">{item.description}</span>
                          )}
                          {item.duration && (
                            <span class="text-[12px] text-accent uppercase tracking-wider font-semibold mt-1">
                              {item.duration}
                            </span>
                          )}
                        </div>
                        <span class="text-[24px] text-accent font-display font-bold shrink-0">{item.price} €</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            {pricingEntry?.data.note && (
              <p class="mt-12 text-center font-sans text-[14px] text-graphite italic">{pricingEntry.data.note}</p>
            )}
          </div>
        ) : (
          <div class="max-w-3xl mx-auto reveal" data-delay="80">
            <ul class="font-sans flex flex-col" role="list">
              {[
                { name: 'Pánsky strih', price: '20' },
                { name: 'Detský strih', price: '16' },
                { name: 'Úprava brady', price: '14' },
                { name: 'Holenie Hot Towel', price: '15' },
                { name: 'Balíček Elegánov', price: '48' },
              ].map((item, idx, arr) => (
                <li class={`flex justify-between items-center py-6 ${idx !== arr.length - 1 ? 'border-b border-subtle/50 border-dashed' : ''}`}>
                  <span class="text-[20px] text-ink font-display font-bold">{item.name}</span>
                  <span class="text-[24px] text-accent font-display font-bold shrink-0">{item.price} €</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        
        <div class="mt-16 text-center reveal" data-delay="160">
           <a
              href="https://pani-elegani.reservio.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-pill py-3.5 px-10 bg-ink font-sans text-[13px] uppercase tracking-widest text-white font-bold hover:bg-ink/80 transition-colors shadow-lg"
            >
              Rezervovať termín
            </a>
        </div>
      </div>
    </section>

    <!-- Recenzie (styled like Blog from the image) -->
    {reviews.length > 0 && (
      <section id="recenzie" class="w-full py-40 bg-darkBg text-white slanted-top relative z-10 px-6">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-20 reveal">
            <p class="text-[13px] tracking-[0.2em] uppercase mb-4 text-accent font-sans font-bold">Skúsenosti klientov</p>
            <div class="flex items-center justify-center gap-6">
              <div class="w-12 h-px bg-white/20"></div>
              <h2 class="text-[48px] leading-[1.2] text-white font-display font-bold">
                Recenzie
              </h2>
              <div class="w-12 h-px bg-white/20"></div>
            </div>
          </div>
          
          <ul class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" role="list">
            {reviews.slice(0, 3).map((r, i) => (
              <li class="reveal bg-ink border border-white/5 p-8 flex flex-col relative group overflow-hidden" data-delay={80 * (i + 1)}>
                <div class="absolute top-0 left-0 w-full h-1 bg-accent transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></div>
                <div class="flex gap-1 text-accent text-lg mb-6" aria-label={`${r.stars} z 5 hviezd`}>
                  {[1, 2, 3, 4, 5].map((s) => (
                    <span aria-hidden="true">{s <= r.stars ? '★' : '☆'}</span>
                  ))}
                </div>
                <p class="text-[16px] leading-relaxed text-white/70 font-sans mb-8 italic">"{r.text}"</p>
                <div class="flex flex-col mt-auto border-t border-white/10 pt-6">
                  <span class="text-[15px] font-bold uppercase tracking-wide text-white font-sans">{r.author}</span>
                  {r.date && <span class="text-[13px] text-white/40 font-sans mt-1 uppercase tracking-wider">{r.date}</span>}
                </div>
              </li>
            ))}
          </ul>
          <div class="mt-16 text-center reveal" data-delay="320">
            <a
              href={googleProfileUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-pill py-3.5 px-8 border border-white/20 bg-transparent font-sans text-[13px] uppercase tracking-widest text-white font-bold hover:bg-white hover:text-ink transition-colors"
            >
              Všetky recenzie na Google
            </a>
          </div>
        </div>
      </section>
    )}
  </main>

  <!-- Footer -->
  <footer class="w-full bg-ink text-white/60 pt-24 pb-12 px-6 border-t border-white/5 relative z-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-start justify-between gap-16">
      
      <!-- Brand & About -->
      <div class="flex flex-col items-start gap-6 max-w-sm">
        <a href="#" class="font-display text-3xl font-bold tracking-[0.1em] text-white uppercase flex items-center gap-2">
          <span class="text-accent">Páni</span> Elegáni
        </a>
        <p class="text-[14px] leading-relaxed font-sans">
          Tradičné holičstvo pre moderného muža. Miesto, kde sa remeslo stretáva s eleganciou a štýlom.
        </p>
      </div>

      <!-- Links & Contact -->
      <div class="flex flex-col sm:flex-row gap-16">
        <div class="flex flex-col gap-4 font-sans">
          <span class="text-[16px] font-display font-bold text-white uppercase tracking-widest mb-2">Kontakt</span>
          <p class="text-[14px]">Sládkovičova 1429<br/>Bánovce nad Bebravou</p>
          <a href="tel:+421911871479" class="text-[14px] hover:text-accent transition-colors text-white/90 font-medium">+421 911 871 479</a>
        </div>
        
        <div class="flex flex-col gap-4 font-sans">
          <span class="text-[16px] font-display font-bold text-white uppercase tracking-widest mb-2">Otváracie hodiny</span>
          <div class="text-[14px] flex flex-col gap-2">
            <div class="flex justify-between gap-8 border-b border-white/10 pb-1">
              <span>Pondelok - Piatok</span>
              <span class="text-white">08:00 - 17:00</span>
            </div>
            <div class="flex justify-between gap-8 border-b border-white/10 pb-1">
              <span>Sobota - Nedeľa</span>
              <span class="text-accent">Zatvorené</span>
            </div>
            <p class="text-xs mt-2 italic text-white/40">* obedná prestávka 12:00 - 13:00</p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="max-w-6xl mx-auto mt-20 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 font-sans text-[12px] uppercase tracking-widest">
      <p>© {new Date().getFullYear()} PÁNI ELEGÁNI. Všetky práva vyhradené.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Instagram</a>
        <a href="#" class="hover:text-white transition-colors">Facebook</a>
      </div>
    </div>
  </footer>

  <script>
    // --- Navbar Scroll Effect ---
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar?.classList.add('bg-ink/95', 'shadow-lg');
        navbar?.classList.remove('bg-transparent', 'border-transparent');
      } else {
        navbar?.classList.remove('bg-ink/95', 'shadow-lg');
        navbar?.classList.add('bg-transparent', 'border-transparent');
      }
    });

    // --- Cenník tabs ---
    document.querySelectorAll('.cennik-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = Number(tab.getAttribute('data-tab-index'));
        const section = tab.closest('section');
        if (!section) return;
        section.querySelectorAll('.cennik-tab').forEach((t) => {
          t.removeAttribute('data-active');
          t.setAttribute('aria-selected', 'false');
        });
        section.querySelectorAll('.cennik-panel').forEach((p) => { (p as HTMLElement).hidden = true; });
        tab.setAttribute('data-active', '');
        tab.setAttribute('aria-selected', 'true');
        const panel = section.querySelector(`.cennik-panel[data-panel-index="${index}"]`) as HTMLElement | null;
        if (panel) {
          panel.hidden = false;
          panel.classList.remove('tab-entering');
          void panel.offsetWidth; // force reflow
          panel.classList.add('tab-entering');
        }
      });
    });

    // --- Scroll reveal ---
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
