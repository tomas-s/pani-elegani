---
import type { Locale } from '../i18n/ui';
import { getStrings } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);

const targetLocale: Locale = locale === 'sk' ? 'en' : 'sk';
const href = targetLocale === 'en' ? '/en/' : '/';
const label = targetLocale === 'en' ? 'EN' : 'SK';
const ariaLabel = targetLocale === 'en' ? t.switchToEn : t.switchToSk;
---

<a
  href={href}
  lang={targetLocale}
  aria-label={ariaLabel}
  title={ariaLabel}
  class="inline-flex w-[2.75rem] shrink-0 items-center justify-center font-sans text-[13px] uppercase tracking-widest font-semibold text-white/70 hover:text-accent transition-colors py-2 text-center"
>
  {label}
</a>
